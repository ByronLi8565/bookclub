{
  "name": "bookclub",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "build": "vite build",
    "deploy": "bun run scripts/predeploy-backup.ts && vite build && wrangler deploy",
    "deploy:no-backup": "vite build && wrangler deploy",
    "destroy": "wrangler delete",
    "secrets:sync": "fnox exec -- bash scripts/sync-secrets.sh",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:visual": "playwright test src/tests/playwright/visual.pw.ts",
    "test:visual:update": "playwright test src/tests/playwright/visual.pw.ts --update-snapshots",
    "info:template": "node scripts/new-info-card.mjs",
    "check": "oxfmt --check && oxlint && tsc --noEmit",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@lexical/markdown": "^0.45.0",
    "@lexical/react": "^0.45.0",
    "@lexical/rich-text": "^0.45.0",
    "@tanstack/react-hotkeys": "^0.10.0",
    "agents": "^0.16.2",
    "effect": "4.0.0-beta.83",
    "epubjs": "^0.3.93",
    "hono": "^4.12.27",
    "lexical": "^0.45.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-swipeable": "^7.0.2",
    "ulidx": "^2.4.1",
    "wouter": "^3.10.0"
  },
  "devDependencies": {
    "@antithesishq/bombadil": "^0.5.0",
    "@cloudflare/vite-plugin": "^1.42.4",
    "@cloudflare/workers-types": "^4.20260630.1",
    "@playwright/test": "^1.61.1",
    "@types/jsdom": "^28.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.72.0",
    "playwright": "^1.61.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.2",
    "vite-plugin-pwa": "^1.3.0",
    "wrangler": "^4.106.0"
  },
  "trustedDependencies": [
    "core-js",
    "es5-ext"
  ]
}
