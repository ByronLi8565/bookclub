{
  "name": "bookclub",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n client,worker \"vite --port 5173\" \"wrangler dev --port 8787\"",
    "dev:worker": "wrangler dev --port 8787",
    "deploy": "alchemy deploy",
    "destroy": "alchemy destroy",
    "typecheck": "tsc --noEmit",
    "serve": "vite --port 5173",
    "test:reader": "bombadil test \"http://localhost:5173/?book=/fixtures/dorian.epub\" bombadil/reader.spec.ts --headless --time-limit 90s --exit-on-violation --output-path .bombadil/reader",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "check": "oxfmt --check && oxlint && tsc --noEmit"
  },
  "dependencies": {
    "@lexical/markdown": "^0.45.0",
    "@lexical/react": "^0.45.0",
    "@lexical/rich-text": "^0.45.0",
    "@lexical/utils": "^0.45.0",
    "@tanstack/react-hotkeys": "^0.10.0",
    "agents": "^0.16.0",
    "effect": "4.0.0-beta.83",
    "epubjs": "^0.3.93",
    "idb": "^8.0.3",
    "lexical": "^0.45.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@antithesishq/bombadil": "^0.5.0",
    "@cloudflare/workers-types": "^4.20250805.0",
    "@effect/platform-bun": "4.0.0-beta.83",
    "@effect/platform-node": "4.0.0-beta.83",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^6.0.2",
    "alchemy": "next",
    "concurrently": "^10.0.3",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.7",
    "wrangler": "^4.100.0"
  },
  "trustedDependencies": [
    "core-js",
    "es5-ext"
  ]
}
